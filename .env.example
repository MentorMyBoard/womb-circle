# ── Copy this file to .env and fill in your real values ──────────────────────

# Server
PORT=3000
NODE_ENV=production

# Admin Login (change this to a strong password!)
ADMIN_PASSWORD=ChangeMe@2025
JWT_SECRET=your-super-secret-jwt-key-change-this

# Razorpay (get from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Membership fee in paise (100 paise = ₹1). Default: ₹5000
MEMBERSHIP_FEE_PAISE=500000

# Brevo (formerly Sendinblue — get from https://app.brevo.com/settings/keys/api)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx
BREVO_SENDER_EMAIL=noreply@wombcircle.com
BREVO_SENDER_NAME=WOMB Circle
BREVO_ADMIN_EMAIL=admin@wombcircle.com

# Site URL (used in emails)
SITE_URL=https://wombcircle.com
